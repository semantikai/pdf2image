{
  "name": "@semantik/root",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "dev:widget": "",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo clean"
  },
  "devDependencies": {
    "@semantik/eslint-config": "workspace:*",
    "@semantik/typescript-config": "workspace:*",
    "prettier": "^3.2.5",
    "turbo": "latest"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "tooling/*",
    "libs/*"
  ],
  "packageManager": "bun@1.1.18",
  "engines": {
    "node": ">=18"
  }
}
